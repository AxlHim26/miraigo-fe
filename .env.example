# Frontend app
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Optional: override server-side base URL resolution if needed
NEXT_PUBLIC_API_BASE_URL=http://localhost:3000

# Backend API
NEXT_PUBLIC_BACKEND_API_URL=http://localhost:8080

# Kanji data directory for local file-backed API routes
KANJI_DATA_DIR=data/kanji

# OpenRouter
# Required for practice / kanji translation routes and helper scripts
OPENROUTER_API_KEY=replace_with_openrouter_api_key
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Optional: if omitted, some routes/scripts fall back to their own model defaults
OPENROUTER_MODEL=gpt-4o-mini

# Optional retry tuning for realtime/practice routes
OPENROUTER_RATE_LIMIT_RETRIES=2
OPENROUTER_RATE_LIMIT_DELAY_MS=1200

# Optional delay for batch translation scripts
OPENROUTER_BATCH_DELAY_MS=3000

# Voice AI backend (ECAPA-TDNN + Whisper)
NEXT_PUBLIC_VOICE_API_URL=http://localhost:8000
